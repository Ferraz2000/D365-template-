<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Testes unitários do assembly de plugins.
    Mesmo TFM do projeto testado (net462). FakeXrmEasy simula o Dataverse e o pipeline.

    FakeXrmEasy.9 = linha 1.x (SDK 9 / Dataverse). A v1 é MIT; v2/v3 exigem chave de
    licença. Ajuste o pacote/versão conforme sua licença — ver docs/architecture/testing.md.
  -->
  <PropertyGroup>
    <TargetFramework>net462</TargetFramework>
    <IsPackable>false</IsPackable>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.9.0" />
    <PackageReference Include="xunit" Version="2.7.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.7">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="FakeXrmEasy.9" Version="1.58.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\plugins\Template.Plugins\Template.Plugins.csproj" />
  </ItemGroup>

</Project>

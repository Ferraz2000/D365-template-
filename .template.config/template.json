{
  "$schema": "http://json.schemastore.org/template",
  "author": "Template D365 CE",
  "classifications": ["D365", "Dataverse", "Plugins", "Web Resources"],
  "identity": "D365CE.VerticalSlice.Template",
  "name": "D365 Customer Engagement — plugins + web resources (vertical slice)",
  "shortName": "d365ce",
  "sourceName": "Template.Plugins",
  "preferNameDirectory": true,
  "symbols": {
    "prefix": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "tpl",
      "replaces": "tpl",
      "fileRename": "tpl",
      "description": "Prefixo do publisher para schema customizado (ex.: ctso). Default: tpl."
    }
  },
  "sources": [
    {
      "exclude": [
        "**/bin/**",
        "**/obj/**",
        "**/node_modules/**",
        "**/dist/**",
        "**/package-lock.json",
        "**/*.user",
        ".git/**",
        ".vs/**",
        ".template.config/**",
        "Template.Pack.*",
        "nupkg/**",
        "TEMPLATE.md",
        "LICENSE",
        "CONTRIBUTING.md",
        ".github/workflows/release.yml",
        "README.md",
        "docs/brain/**",
        "seed/**"
      ],
      "rename": {
        "README.project.md": "README.md"
      }
    },
    {
      "source": "seed/brain/",
      "target": "docs/brain/"
    }
  ]
}

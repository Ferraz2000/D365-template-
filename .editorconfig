root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C#
[*.cs]
indent_size = 4
csharp_new_line_before_open_brace = all
dotnet_sort_system_directives_first = true
csharp_prefer_braces = true:suggestion

# Projetos / XML
[*.{csproj,props,targets,config,xml}]
indent_size = 2

# Web (TypeScript / JS / JSON / YAML)
[*.{ts,js,json,yml,yaml}]
indent_size = 2

# Markdown — não cortar trailing (dois espaços = quebra de linha)
[*.md]
trim_trailing_whitespace = false

# Shell (githooks)
[*.sh]
end_of_line = lf

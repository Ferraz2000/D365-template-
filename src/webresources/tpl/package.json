{
  "name": "tpl-webresources",
  "version": "0.1.0",
  "private": true,
  "description": "Web resources (TypeScript, módulos ES + bundle) do template D365 CE — prefixo tpl.",
  "scripts": {
    "build": "esbuild src/account/form.ts --bundle --format=iife --global-name=Tpl --sourcemap --outfile=dist/account/form.js",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/jest": "^29.5.12",
    "@types/xrm": "^9.0.0",
    "esbuild": "^0.20.2",
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "xrm-mock": "^3.5.0"
  }
}
